# Environment configuration for dbxmetagen deployment
# Copy to dev.env (or prod.env) and fill in your values:
#   cp example.env dev.env

# Required: Databricks workspace URL
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Required: Target catalog for metadata results
catalog_name=your_catalog

# Required: Target schema (default: metadata_results)
schema_name=metadata_results

# Required: SQL warehouse ID for dashboard queries and DDL execution
warehouse_id=your_warehouse_id

# Optional: Cluster node type for job clusters (default: i3.2xlarge for AWS)
# For Azure use Standard_D8s_v3, Standard_E4ds_v4, etc.
# For GCP use n2-standard-8, n2-highmem-4, etc.
# node_type=Standard_D8s_v3

# Optional: Groups to grant read access on created objects (comma-separated)
# permission_groups=account users

# Optional: Users to grant read access on created objects (comma-separated)
# permission_users=user1@company.com,user2@company.com
