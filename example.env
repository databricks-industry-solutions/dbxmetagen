# Environment configuration for dbxmetagen deployment
# Copy to dev.env (or prod.env) and fill in your values:
#   cp example.env dev.env

# Required: Databricks workspace URL
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Required: Target catalog for metadata results
catalog_name=your_catalog

# Required: Target schema (default: metadata_results)
schema_name=metadata_results

# Required: SQL warehouse ID for dashboard queries and DDL execution
warehouse_id=your_warehouse_id

# Optional: Cluster node type for job clusters (default: i3.2xlarge for AWS)
# For Azure use Standard_D8s_v3, Standard_E4ds_v4, etc.
# For GCP use n2-standard-8, n2-highmem-4, etc.
# node_type=Standard_D8s_v3

# Optional: Cluster policy ID for classic (non-serverless) job clusters.
# Enforces governance/cost policies on all job compute.
# Get the ID from Settings > Compute > Cluster policies > (select policy) > Policy ID.
# policy_id=001DD81A49229D7C

# Optional: Serverless budget policy ID for serverless jobs.
# Adds cost attribution tags to serverless compute for billing.
# Get the ID from Settings > Compute > Serverless usage policies.
# budget_policy_id=01234567-89ab-cdef-0123-456789abcdef

# Optional: Groups to grant CAN_USE on the app and read access on created objects (comma-separated).
# These groups are added to the app's DABs permissions on every deploy, so access persists.
# permission_groups=account users

# Optional: Users to grant CAN_USE on the app and read access on created objects (comma-separated).
# The deploying user is automatically excluded (they already have CAN_MANAGE via top-level permissions).
# permission_users=user1@company.com,user2@company.com

# Optional: Enable On-Behalf-Of user auth. When true, catalog browsing and SQL queries
# run under the logged-in user's identity. Requires workspace admin to enable user auth
# for the app. (default: false)
# enable_obo=true

# Optional: Lakebase configuration for accelerated graph queries in the dashboard.
# Run sync_graph_lakebase_job to replicate graph tables to Lakebase.
# The app auto-detects Lakebase when the database resource is attached in the Apps UI.
# lakebase_catalog=dbxmetagen_graphrag
# lakebase_instance_name=dbxmetagen
