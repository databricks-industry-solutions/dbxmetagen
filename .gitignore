# Deployment -- build-hook outputs (generated by scripts/build_artifacts.sh
# during `databricks bundle deploy`). databricks.yml, app.yaml, and
# resources/apps/dbxmetagen_app.yml are now STATIC committed files, not generated.
apps/dbxmetagen-app/app/requirements.txt
apps/dbxmetagen-app/app/dbxmetagen-*.whl
apps/dbxmetagen-app/app/configurations/
databricks_final.yml
databricks_final.yml.tmp
# Per-workspace bundle variable values (never commit). DAB auto-loads
# .databricks/bundle/<target>/variable-overrides.json (the .databricks/ dir is
# already ignored above); a repo-root variable-overrides.json is also ignored
# for the legacy layout. variable-overrides.example.json IS committed (placeholders).
variable-overrides.json
!variable-overrides.example.json
pyproject.toml.build_bak

