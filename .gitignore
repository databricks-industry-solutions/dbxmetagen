*.bkp
*.backup

# Environment-specific config (not committed)

*.env
!example.env

# Internal roadmaps (not shipped)
ROADMAP.md

# docs/: ignore by default; whitelist only public paths (README + Ontology tab). Avoid !docs/ — it re-includes the whole tree.
docs/**
!docs/formal_semantics.md
!docs/CONFIGURATION.md
!docs/consumer-guide.md
!docs/MANUAL_DEPLOYMENT.md
!docs/MCP_SERVERS.md
!docs/DEPENDENCIES.md
!docs/metadata_governance_workflow.md
!docs/DOMAIN_ONTOLOGY_ARCHITECTURE.md
!docs/QA_CHECKLIST.md
!docs/PERMISSIONS.md
!docs/CONSOLIDATED_ROADMAP.md

.cursor/*
!.cursor/rules/
.cursor/rules/roadmap-awareness.mdc
!.cursor/skills/
.cursor/skills/*
!.cursor/skills/dbxmetagen-development/
